generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Status {
  active
  inactive
}

enum Role {
  admin
  esg_manager
  department_head
  employee
  compliance_officer
}

enum SourceModule {
  purchase
  manufacturing
  expense
  fleet
  manual
}

enum GoalStatus {
  active
  on_track
  completed
  missed
}

enum ApprovalStatus {
  pending
  approved
  rejected
}

enum ChallengeStatus {
  draft
  active
  under_review
  completed
  archived
}

enum Difficulty {
  easy
  medium
  hard
}

enum AuditStatus {
  completed
  under_review
}

enum Severity {
  low
  medium
  high
  critical
}

enum IssueStatus {
  open
  resolved
}

enum CategoryType {
  csr_activity
  challenge
}

// ---------------- MASTER DATA (Member A) ----------------

model Department {
  id              String   @id @default(uuid())
  name            String
  code            String   @unique
  headEmployeeId  String?
  parentDeptId    String?
  parent          Department?  @relation("DeptHierarchy", fields: [parentDeptId], references: [id])
  children        Department[] @relation("DeptHierarchy")
  employeeCount   Int      @default(0)
  status          Status   @default(active)
  createdAt       DateTime @default(now())

  employees            Employee[]
  environmentalGoals   EnvironmentalGoal[]
  carbonTransactions   CarbonTransaction[]
  csrActivities        CSRActivity[]
  audits               Audit[]
  complianceIssues     ComplianceIssue[]
  departmentScores     DepartmentScore[]
}

model Employee {
  id            String   @id @default(uuid())
  name          String
  email         String   @unique
  passwordHash  String
  departmentId  String
  department    Department @relation(fields: [departmentId], references: [id])
  role          Role     @default(employee)
  xpPoints      Int      @default(0)
  status        Status   @default(active)
  createdAt     DateTime @default(now())

  participations       EmployeeParticipation[]
  challengeEntries      ChallengeParticipation[]
  policyAcks            PolicyAcknowledgement[]
  ownedIssues           ComplianceIssue[] @relation("IssueOwner")
  auditsConducted       Audit[]
  redemptions           RewardRedemption[]
  notifications         Notification[]
  badges                EmployeeBadge[]
}

model Category {
  id      String       @id @default(uuid())
  name    String
  type    CategoryType
  status  Status       @default(active)

  csrActivities CSRActivity[]
  challenges    Challenge[]
}

// ---------------- ENVIRONMENTAL (Member A) ----------------

model EmissionFactor {
  id             String   @id @default(uuid())
  activityType   String
  factorValue    Decimal  @db.Decimal(12, 4)
  unit           String
  source         String?
  effectiveDate  DateTime @default(now())

  productProfiles     ProductESGProfile[]
  carbonTransactions  CarbonTransaction[]
}

model ProductESGProfile {
  id               String   @id @default(uuid())
  productName      String
  emissionFactorId String
  emissionFactor   EmissionFactor @relation(fields: [emissionFactorId], references: [id])
  lifecycleNotes   String?
}

model EnvironmentalGoal {
  id            String     @id @default(uuid())
  departmentId  String
  department    Department @relation(fields: [departmentId], references: [id])
  name          String
  targetCo2     Decimal    @db.Decimal(12, 2)
  currentCo2    Decimal    @db.Decimal(12, 2) @default(0)
  deadline      DateTime?
  status        GoalStatus @default(active)
}

model CarbonTransaction {
  id               String       @id @default(uuid())
  departmentId     String
  department       Department   @relation(fields: [departmentId], references: [id])
  emissionFactorId String
  emissionFactor   EmissionFactor @relation(fields: [emissionFactorId], references: [id])
  sourceModule     SourceModule
  quantity         Decimal      @db.Decimal(12, 4)
  co2Calculated    Decimal      @db.Decimal(12, 4)
  transactionDate  DateTime     @default(now())
  autoGenerated    Boolean      @default(false)
}

// ---------------- SOCIAL (Member B) ----------------

model CSRActivity {
  id                String   @id @default(uuid())
  title             String
  categoryId        String
  category          Category @relation(fields: [categoryId], references: [id])
  departmentId      String
  department        Department @relation(fields: [departmentId], references: [id])
  description       String?
  evidenceRequired  Boolean  @default(false)
  status            Status   @default(active)
  createdAt         DateTime @default(now())

  participations EmployeeParticipation[]
}

model EmployeeParticipation {
  id              String         @id @default(uuid())
  employeeId      String
  employee        Employee       @relation(fields: [employeeId], references: [id])
  activityId      String
  activity        CSRActivity    @relation(fields: [activityId], references: [id])
  proofUrl        String?
  approvalStatus  ApprovalStatus @default(pending)
  pointsEarned    Int            @default(0)
  completionDate  DateTime?
}

// ---------------- GOVERNANCE (Member C) ----------------

model ESGPolicy {
  id           String   @id @default(uuid())
  title        String
  content      String?
  version      String?
  publishedAt  DateTime @default(now())

  acknowledgements PolicyAcknowledgement[]
}

model PolicyAcknowledgement {
  id               String    @id @default(uuid())
  policyId         String
  policy           ESGPolicy @relation(fields: [policyId], references: [id])
  employeeId       String
  employee         Employee  @relation(fields: [employeeId], references: [id])
  acknowledgedAt   DateTime  @default(now())
}

model Audit {
  id             String      @id @default(uuid())
  title          String
  departmentId   String
  department     Department  @relation(fields: [departmentId], references: [id])
  auditorId      String
  auditor        Employee    @relation(fields: [auditorId], references: [id])
  auditDate      DateTime?
  findings       String?
  status         AuditStatus @default(under_review)

  complianceIssues ComplianceIssue[]
}

model ComplianceIssue {
  id             String      @id @default(uuid())
  auditId        String?
  audit          Audit?      @relation(fields: [auditId], references: [id])
  departmentId   String
  department     Department  @relation(fields: [departmentId], references: [id])
  severity       Severity
  description    String?
  ownerId        String
  owner          Employee    @relation("IssueOwner", fields: [ownerId], references: [id])
  dueDate        DateTime
  status         IssueStatus @default(open)
}

// ---------------- GAMIFICATION (Member C) ----------------

model Challenge {
  id                String          @id @default(uuid())
  title             String
  categoryId        String
  category          Category        @relation(fields: [categoryId], references: [id])
  description       String?
  xp                Int
  difficulty        Difficulty
  evidenceRequired  Boolean         @default(false)
  deadline          DateTime?
  status            ChallengeStatus @default(draft)

  participations ChallengeParticipation[]
}

model ChallengeParticipation {
  id              String         @id @default(uuid())
  challengeId     String
  challenge       Challenge      @relation(fields: [challengeId], references: [id])
  employeeId      String
  employee        Employee       @relation(fields: [employeeId], references: [id])
  progress        Int            @default(0)
  proofUrl        String?
  approvalStatus  ApprovalStatus @default(pending)
  xpAwarded       Int            @default(0)
}

model Badge {
  id               String   @id @default(uuid())
  name             String
  description      String?
  unlockRuleType   String
  unlockRuleValue  Int
  iconUrl          String?

  employeeBadges EmployeeBadge[]
}

model EmployeeBadge {
  id          String   @id @default(uuid())
  employeeId  String
  employee    Employee @relation(fields: [employeeId], references: [id])
  badgeId     String
  badge       Badge    @relation(fields: [badgeId], references: [id])
  awardedAt   DateTime @default(now())
}

model Reward {
  id              String   @id @default(uuid())
  name            String
  description     String?
  pointsRequired  Int
  stock           Int      @default(0)
  status          Status   @default(active)

  redemptions RewardRedemption[]
}

model RewardRedemption {
  id              String   @id @default(uuid())
  employeeId      String
  employee        Employee @relation(fields: [employeeId], references: [id])
  rewardId        String
  reward          Reward   @relation(fields: [rewardId], references: [id])
  pointsDeducted  Int
  redeemedAt      DateTime @default(now())
}

// ---------------- SCORING + SETTINGS (Member D) ----------------

model DepartmentScore {
  id                  String     @id @default(uuid())
  departmentId        String
  department          Department @relation(fields: [departmentId], references: [id])
  environmentalScore  Decimal    @db.Decimal(5, 2)
  socialScore         Decimal    @db.Decimal(5, 2)
  governanceScore     Decimal    @db.Decimal(5, 2)
  totalScore          Decimal    @db.Decimal(5, 2)
  calculatedAt        DateTime   @default(now())
}

model ESGConfiguration {
  id                     String  @id @default(uuid())
  envWeight              Decimal @db.Decimal(4, 2) @default(0.40)
  socialWeight           Decimal @db.Decimal(4, 2) @default(0.30)
  governanceWeight       Decimal @db.Decimal(4, 2) @default(0.30)
  autoEmissionCalc       Boolean @default(true)
  requireEvidenceCsr     Boolean @default(true)
  autoBadgeAward         Boolean @default(true)
  emailAlertsCompliance  Boolean @default(true)
}

model Notification {
  id          String   @id @default(uuid())
  employeeId  String
  employee    Employee @relation(fields: [employeeId], references: [id])
  type        String
  message     String
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())
}